LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_DEFAULT_MODEL=

# ============================================================
# AI Routing and Fallback Control
# ============================================================

DEFAULT_AI_PROVIDER=openai
DEFAULT_FALLBACK_PROVIDER=anthropic
SECOND_FALLBACK_PROVIDER=google
THIRD_FALLBACK_PROVIDER=openrouter
LOCAL_FALLBACK_PROVIDER=ollama

ENABLE_AI_FALLBACK=true
ENABLE_LOCAL_MODEL_FALLBACK=true
ENABLE_COST_OPTIMIZATION=true
ENABLE_TOKEN_BUDGET_CONTROL=true

MAX_RETRY_PER_PROVIDER=2
PROVIDER_TIMEOUT_SECONDS=60

# If true, system should prefer cheaper models for bulk generation tasks.
PREFER_CHEAP_MODEL_FOR_BULK_TASKS=true

# If true, system should prefer stronger models for reviewer, strategy, and orchestration tasks.
PREFER_REASONING_MODEL_FOR_CRITICAL_TASKS=true

# ============================================================
# Safety Rules
# ============================================================

ALLOW_TICKET_CREATION=false
ALLOW_PRODUCTION_DATA=false
ALLOW_DESTRUCTIVE_DB_VALIDATION=false
ALLOW_EXTERNAL_AI_FOR_SENSITIVE_DATA=false
ALLOW_LOCAL_AI_FOR_PRIVATE_DATA=true