{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "login-request.schema.json",
  "title": "Login Request Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["email", "password"],
  "properties": {
    "email": {
      "type": "string",
      "minLength": 5,
      "maxLength": 254,
      "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
    },
    "password": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    }
  }
}
